---
import type { SiteContent } from '../i18n';
import ProcessIcon from './ProcessIcon.astro';

interface Props {
  content: SiteContent;
}

const { process } = Astro.props.content;
---

<section class="relative overflow-hidden bg-white py-20 md:py-28">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-b from-section-alt/45 via-transparent to-warm/25"></div>
    <div
      class="absolute -right-16 top-1/2 hidden h-[28rem] w-[28rem] -translate-y-1/2 rounded-full border border-border/30 lg:block"
    >
    </div>
    <div
      class="absolute -left-24 bottom-0 hidden h-64 w-64 rounded-full bg-section-alt/40 lg:block"
    >
    </div>
  </div>

  <div class="relative mx-auto max-w-7xl px-5 md:px-8">
    <div class="section-header text-center" data-animate>
      <p class="section-label mb-5">{process.label}</p>
      <h2 class="section-title">{process.title}</h2>
    </div>

    <ol class="process-grid relative mx-auto grid max-w-5xl grid-cols-2 gap-px bg-border lg:grid-cols-4">
      <div
        class="pointer-events-none absolute left-[12.5%] right-[12.5%] top-[calc(50%-0.5px)] hidden h-px origin-left bg-charcoal/10 lg:block"
        data-animate="line"
        data-delay="1"
        aria-hidden="true"
      />
      {
        process.steps.map((step, index) => (
          <li
            class="process-step group relative overflow-hidden bg-white px-5 py-9 text-center md:px-6 md:py-10"
            data-animate
            data-delay={String(index + 1)}
          >
            <span
              class="process-watermark pointer-events-none absolute -bottom-2 -right-1 font-serif text-[4.5rem] leading-none text-border/25 select-none md:text-[5rem]"
              aria-hidden="true"
            >
              {String(index + 1).padStart(2, '0')}
            </span>

            <div
              class="pointer-events-none absolute inset-0 bg-gradient-to-br from-cream/0 via-cream/0 to-warm/0 opacity-0 transition-opacity duration-500 group-hover:opacity-100 group-hover:from-cream/60 group-hover:to-warm/30"
              aria-hidden="true"
            />

            <span
              class="step-badge relative z-10 mx-auto mb-5 flex h-11 w-11 items-center justify-center border border-border bg-white shadow-[0_1px_0_rgba(26,26,26,0.03)]"
            >
              <span class="text-[9px] font-normal uppercase tracking-[0.22em] text-stone transition-colors duration-300 group-hover:text-charcoal">
                {String(index + 1).padStart(2, '0')}
              </span>
              <ProcessIcon
                index={index}
                class="process-step-icon absolute opacity-0 transition-all duration-300 group-hover:opacity-100"
              />
            </span>

            <p class="relative z-10 mx-auto max-w-[9rem] text-sm leading-relaxed text-muted transition-colors duration-300 group-hover:text-charcoal">
              {step}
            </p>

            {index < process.steps.length - 1 && (index + 1) % 4 !== 0 && (
              <span
                class="process-connector pointer-events-none absolute -right-px top-1/2 z-20 hidden h-px w-3 -translate-y-1/2 bg-charcoal/15 lg:block"
                aria-hidden="true"
              />
            )}
          </li>
        ))
      }
    </ol>
  </div>
</section>
