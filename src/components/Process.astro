---
import { process } from '../data/zh';
---

<section class="bg-section-alt py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="section-header">
      <p class="section-label mb-4">{process.label}</p>
      <h2 class="section-title">{process.title}</h2>
    </div>

    <div class="relative mx-auto max-w-xl lg:max-w-none">
      <ol class="flex flex-col lg:grid lg:grid-cols-4 lg:gap-x-5 lg:gap-y-0">
        {
          process.steps.map((step, index) => (
            <>
              <li class="group relative flex gap-4 pb-6 last:pb-0 lg:flex-col lg:items-center lg:pb-0 lg:text-center">
                {index < process.steps.length - 1 && (
                  <div
                    class="absolute left-[1.375rem] top-11 bottom-0 w-px bg-gradient-to-b from-gold/35 via-gold/15 to-transparent lg:hidden"
                    aria-hidden="true"
                  ></div>
                )}

                {index % 4 !== 3 && index < process.steps.length - 1 && (
                  <div
                    class="pointer-events-none absolute -right-2.5 top-[1.375rem] z-0 hidden w-5 text-gold/35 lg:block"
                    aria-hidden="true"
                  >
                    <svg viewBox="0 0 20 8" fill="none" class="h-2 w-full">
                      <path
                        d="M0 4h14m0 0-2.5-2.5M14 4l-2.5 2.5"
                        stroke="currentColor"
                        stroke-width="1"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </div>
                )}

                <span class="relative z-10 flex h-11 w-11 shrink-0 items-center justify-center border border-gold/30 bg-white font-serif text-sm text-gold shadow-sm transition-all duration-300 group-hover:border-gold group-hover:shadow-md lg:h-12 lg:w-12 lg:text-base">
                  {String(index + 1).padStart(2, '0')}
                </span>

                <div class="flex min-h-11 flex-1 items-center rounded-sm border border-charcoal/8 bg-white px-5 py-3.5 shadow-[0_2px_12px_-4px_rgba(26,26,26,0.06)] transition-all duration-300 group-hover:border-gold/25 group-hover:shadow-[0_4px_20px_-6px_rgba(26,26,26,0.1)] lg:mt-5 lg:min-h-[4.5rem] lg:w-full lg:justify-center lg:px-4 lg:py-5">
                  <span class="text-sm leading-relaxed text-charcoal lg:font-serif lg:text-base">
                    {step}
                  </span>
                </div>
              </li>

              {index === 3 && (
                <li
                  class="hidden lg:col-span-4 lg:flex lg:items-center lg:justify-center lg:py-8"
                  aria-hidden="true"
                >
                  <div class="flex flex-col items-center gap-2">
                    <div class="h-10 w-px bg-gradient-to-b from-gold/30 to-gold/10"></div>
                    <div class="flex h-8 w-8 items-center justify-center rounded-full border border-gold/25 bg-white text-gold shadow-sm">
                      <svg viewBox="0 0 12 12" fill="none" class="h-3 w-3">
                        <path
                          d="M6 2v8m0 0-2.5-2.5M6 10l2.5-2.5"
                          stroke="currentColor"
                          stroke-width="1.25"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </div>
                    <div class="h-10 w-px bg-gradient-to-b from-gold/10 to-transparent"></div>
                  </div>
                </li>
              )}
            </>
          ))
        }
      </ol>
    </div>
  </div>
</section>
