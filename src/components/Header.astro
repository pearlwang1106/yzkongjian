---
import type { Locale, SiteContent } from '../i18n';
import { getAlternateLocale, getLocalePath } from '../i18n';

interface Props {
  content: SiteContent;
  locale: Locale;
}

const { content, locale } = Astro.props;
const { site, nav, ui } = content;
const homePath = getLocalePath(locale);
const altLocale = getAlternateLocale(locale);
const altPath = getLocalePath(altLocale);
---

<header class="sticky top-0 z-50 border-b border-border bg-cream/95 backdrop-blur-sm" data-header>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-5 md:px-8">
    <a href={homePath} class="font-serif text-base tracking-[0.15em] text-charcoal md:text-lg">
      {site.brand}
    </a>

    <div class="flex items-center gap-6 md:gap-10">
      <nav class="hidden items-center gap-10 md:flex lg:gap-12" aria-label={ui.mainNav}>
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="text-xs font-normal uppercase tracking-[0.3em] text-charcoal transition-opacity hover:opacity-50 md:text-sm"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <a
        href={altPath}
        class="text-xs font-normal uppercase tracking-[0.25em] text-stone transition-colors hover:text-charcoal md:text-sm"
        aria-label={ui.langSwitchLabel}
        hreflang={altLocale === 'zh' ? 'zh-CN' : 'en'}
      >
        {ui.langSwitch}
      </a>

      <button
        id="menu-toggle"
        type="button"
        class="flex h-10 w-10 items-center justify-center md:hidden"
        aria-label={ui.openMenu}
        aria-expanded="false"
        data-open-label={ui.openMenu}
        data-close-label={ui.closeMenu}
      >
        <span class="relative block h-3 w-5">
          <span class="menu-line absolute left-0 top-0 block h-px w-full bg-charcoal transition-all"
          ></span>
          <span
            class="menu-line absolute left-0 top-1/2 block h-px w-full -translate-y-1/2 bg-charcoal transition-all"
          ></span>
          <span class="menu-line absolute bottom-0 left-0 block h-px w-full bg-charcoal transition-all"
          ></span>
        </span>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-border bg-cream px-5 py-8 md:hidden"
    aria-label={ui.mobileNav}
  >
    <ul class="flex flex-col gap-6">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-xs font-normal uppercase tracking-[0.3em] text-charcoal md:text-sm"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    const openLabel = toggle.dataset.openLabel ?? 'Open menu';
    const closeLabel = toggle.dataset.closeLabel ?? 'Close menu';
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? closeLabel : openLabel);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      const openLabel = toggle?.dataset.openLabel ?? 'Open menu';
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', openLabel);
    });
  });
</script>
