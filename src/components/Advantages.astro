---
import { advantages } from '../data/zh';
---

<section class="bg-white py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="section-header">
      <p class="section-label mb-4">{advantages.label}</p>
      <h2 class="section-title">{advantages.title}</h2>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8">
      {
        advantages.items.map((item) => (
          <article class="group relative border-l-2 border-gold/20 bg-section-alt/50 px-6 py-8 transition-all duration-300 hover:border-gold hover:bg-section-alt">
            <p class="font-serif text-4xl leading-none text-gold/70 transition-colors group-hover:text-gold">
              {item.number}
            </p>
            <h3 class="mt-5 font-serif text-lg text-charcoal md:text-xl">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
