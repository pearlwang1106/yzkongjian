---
import type { SiteContent } from '../i18n';
import EuropeanIcon from './EuropeanIcon.astro';

interface Props {
  content: SiteContent;
}

const { advantages } = Astro.props.content;
---

<section class="border-t border-border bg-section-alt py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="section-header text-center" data-animate>
      <p class="section-label mb-5">{advantages.label}</p>
      <h2 class="section-title">{advantages.title}</h2>
    </div>

    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8">
      {
        advantages.items.map((item, index) => (
          <article class="advantage-card border-t border-border pt-8" data-animate data-delay={String(index + 1)}>
            <div class="icon-box mb-6 flex h-12 w-12 items-center justify-center border border-border bg-white">
              <EuropeanIcon name={item.icon} />
            </div>
            <p class="text-[10px] font-normal uppercase tracking-[0.3em] text-stone">
              {item.number}
            </p>
            <h3 class="mt-4 font-serif text-lg font-normal text-charcoal md:text-xl">
              {item.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
