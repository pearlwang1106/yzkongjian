---
import { cta } from '../data/zh';
---

<section id="contact" class="relative overflow-hidden bg-charcoal py-24 md:py-32">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(197,160,89,0.12),transparent_60%)]" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-3xl px-5 text-center md:px-8">
    <p class="section-label mb-6">{cta.label}</p>
    <h2 class="font-serif text-3xl text-white md:text-4xl lg:text-5xl">{cta.title}</h2>
    <div class="mx-auto mt-8 h-px w-12 bg-gold/60" aria-hidden="true"></div>
    <p class="mt-8 font-serif text-base italic text-white/65 md:text-lg">{cta.quote}</p>
    <p class="mt-10 font-serif text-2xl tracking-wide text-gold md:text-3xl">{cta.contact}</p>
    <a
      href="#contact"
      class="mt-10 inline-flex items-center justify-center bg-gold px-10 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-charcoal shadow-lg transition-all hover:-translate-y-0.5 hover:bg-gold/90 hover:shadow-xl md:mt-12 md:px-14 md:py-5"
    >
      {cta.button}
    </a>
  </div>
</section>
