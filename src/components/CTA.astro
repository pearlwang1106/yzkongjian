---
import type { SiteContent } from '../i18n';

interface Props {
  content: SiteContent;
}

const { cta } = Astro.props.content;
---

<section id="contact" class="bg-charcoal py-24 md:py-32">
  <div class="mx-auto max-w-2xl px-5 text-center md:px-8">
    <p class="section-label mb-8 text-stone" data-animate>{cta.label}</p>
    <h2 class="font-serif text-3xl font-normal text-white md:text-4xl lg:text-5xl" data-animate data-delay="1">
      {cta.title}
    </h2>
    <div class="mx-auto mt-10 h-px w-10 bg-stone/40" data-animate="line-center" data-delay="2" aria-hidden="true"></div>
    <p class="mt-10 text-sm leading-[2] text-stone md:text-base" data-animate data-delay="2">{cta.quote}</p>
    <p class="mt-10 font-serif text-xl tracking-wide text-white md:text-2xl" data-animate data-delay="3">{cta.contact}</p>
    <a href="#contact" class="btn-primary mt-12 border border-white/20 bg-white text-charcoal hover:bg-stone hover:text-white md:mt-14" data-animate data-delay="4">
      {cta.button}
    </a>
  </div>
</section>
