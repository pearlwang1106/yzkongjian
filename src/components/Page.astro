---
import type { Locale, SiteContent } from '../i18n';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Philosophy from '../components/Philosophy.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Portfolio from '../components/Portfolio.astro';
import Advantages from '../components/Advantages.astro';
import Process from '../components/Process.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

interface Props {
  content: SiteContent;
  locale: Locale;
}

const { content, locale } = Astro.props;
---

<Layout
  title={content.site.title}
  description={content.site.description}
  lang={content.site.lang}
  locale={locale}
>
  <Header content={content} locale={locale} />
  <main class="overflow-x-hidden">
    <Hero content={content} />
    <Philosophy content={content} />
    <About content={content} />
    <Services content={content} />
    <Portfolio content={content} />
    <Advantages content={content} />
    <Process content={content} />
    <FAQ content={content} />
    <CTA content={content} />
  </main>
  <Footer content={content} />
</Layout>
