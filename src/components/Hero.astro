---
import type { SiteContent } from '../i18n';
import { imageSrc } from '../utils/image';

interface Props {
  content: SiteContent;
}

const { hero } = Astro.props.content;
---

<section class="bg-cream" data-hero>
  <div class="mx-auto max-w-7xl px-5 pt-10 pb-12 md:px-8 md:pt-14 md:pb-16 lg:pt-16 lg:pb-20">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <p class="section-label mb-6" data-animate>{hero.label}</p>
        <h1
          class="font-serif text-4xl font-normal leading-[1.2] text-charcoal md:text-5xl lg:text-[3.5rem] lg:leading-[1.15]"
          data-animate
          data-delay="1"
        >
          {hero.title}
        </h1>
        <p class="mt-8 max-w-md text-sm leading-[2] text-muted md:text-base" data-animate data-delay="2">
          {hero.subtitle}
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center" data-animate data-delay="3">
          <a href="#contact" class="btn-primary gap-3">
            {hero.primaryBtn}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1"></path>
            </svg>
          </a>
          <a href="#portfolio" class="btn-outline">
            {hero.secondaryBtn}
          </a>
        </div>
      </div>

      <div class="relative lg:pl-4" data-animate="image" data-delay="2">
        <div class="image-frame image-frame-back hidden lg:block" aria-hidden="true"></div>
        <div class="relative overflow-hidden layout-offset-right">
          <img
            src={imageSrc(hero.image)}
            alt={hero.imageAlt}
            class="aspect-[3/4] w-full object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
</section>
