---
import type { SiteContent } from '../i18n';

interface Props {
  content: SiteContent;
}

const { faq } = Astro.props.content;
---

<section id="faq" class="border-t border-border bg-cream py-20 md:py-28">
  <div class="mx-auto max-w-2xl px-5 md:px-8">
    <div class="section-header text-center" data-animate>
      <p class="section-label mb-5">{faq.label}</p>
      <h2 class="section-title">{faq.title}</h2>
    </div>

    <dl class="divide-y divide-border">
      {
        faq.items.map((item, index) => (
          <div class="py-8 first:pt-0" data-animate data-delay={String(index + 1)}>
            <dt class="font-serif text-lg font-normal text-charcoal md:text-xl">
              {item.question}
            </dt>
            <dd class="mt-4 text-sm leading-[1.9] text-muted md:text-base">{item.answer}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
