---
import { faq } from '../data/zh';
---

<section id="faq" class="bg-white py-20 md:py-28">
  <div class="mx-auto max-w-3xl px-5 md:px-8">
    <div class="section-header">
      <p class="section-label mb-4">{faq.label}</p>
      <h2 class="section-title">{faq.title}</h2>
    </div>

    <dl class="space-y-4">
      {
        faq.items.map((item) => (
          <div class="border border-charcoal/8 bg-section-alt/40 px-6 py-7 transition-colors duration-300 hover:border-gold/25 hover:bg-section-alt/70 md:px-8">
            <dt class="font-serif text-lg text-charcoal md:text-xl">{item.question}</dt>
            <dd class="mt-3 text-sm leading-relaxed text-muted md:text-base">{item.answer}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
