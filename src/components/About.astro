---
import type { SiteContent } from '../i18n';

interface Props {
  content: SiteContent;
}

const { about } = Astro.props.content;
---

<section id="about" class="bg-section-alt py-20 md:py-28">
  <div class="mx-auto max-w-4xl px-5 text-center md:px-8">
    <p class="section-label mb-10" data-animate>{about.label}</p>
    {
      about.paragraphs.map((paragraph, index) => (
        <p
          class="mb-8 text-sm leading-[2.2] text-muted last:mb-0 md:text-base"
          data-animate
          data-delay={String(index + 1)}
        >
          {paragraph}
        </p>
      ))
    }
  </div>
</section>
