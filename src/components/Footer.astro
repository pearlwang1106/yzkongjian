---
import { site, footer } from '../data/zh';
---

<footer class="border-t border-charcoal/6 bg-section-alt">
  <div class="mx-auto max-w-7xl px-5 py-16 md:px-8 md:py-20">
    <div class="grid gap-12 md:grid-cols-[1.2fr_1fr] lg:gap-20">
      <div>
        <p class="font-serif text-lg tracking-[0.15em] text-charcoal">{site.brand}</p>
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-muted">{footer.about}</p>
      </div>

      <div class="grid grid-cols-2 gap-8 sm:gap-12">
        {
          footer.columns.map((column) => (
            <div>
              <p class="mb-5 text-[11px] font-medium uppercase tracking-[0.25em] text-charcoal">
                {column.title}
              </p>
              <ul class="space-y-3">
                {column.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-sm text-muted transition-colors hover:text-gold"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-4 border-t border-charcoal/8 pt-8 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-muted">{footer.copyright}</p>
      <div class="flex gap-6">
        {
          footer.social.map((item) => (
            <a
              href={item.href}
              class="text-[11px] font-medium uppercase tracking-[0.2em] text-charcoal transition-colors hover:text-gold"
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
