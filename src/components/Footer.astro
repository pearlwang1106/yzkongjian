---
import type { SiteContent } from '../i18n';

interface Props {
  content: SiteContent;
}

const { site, footer } = Astro.props.content;
---

<footer class="border-t border-border bg-section-alt">
  <div class="mx-auto max-w-7xl px-5 py-16 md:px-8 md:py-20">
    <div class="grid gap-16 md:grid-cols-[1.2fr_1fr] lg:gap-24">
      <div>
        <p class="font-serif text-base tracking-[0.1em] text-charcoal">{site.brand}</p>
        <p class="mt-6 max-w-sm text-sm leading-[1.9] text-muted">{footer.about}</p>
      </div>

      <div class="grid grid-cols-2 gap-12">
        {
          footer.columns.map((column) => (
            <div>
              <p class="mb-6 text-[10px] font-normal uppercase tracking-[0.3em] text-charcoal">
                {column.title}
              </p>
              <ul class="space-y-4">
                {column.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-sm text-muted transition-opacity hover:opacity-60"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-16 flex flex-col gap-4 border-t border-border pt-8 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-muted">{footer.copyright}</p>
      <div class="flex gap-8">
        {
          footer.social.map((item) => (
            <a
              href={item.href}
              class="text-[10px] font-normal uppercase tracking-[0.25em] text-charcoal transition-opacity hover:opacity-50"
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
