---
import { portfolio } from '../data/zh';
---

<section id="portfolio" class="bg-section-alt py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="mb-10 flex flex-col gap-6 md:mb-16 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="section-label mb-4">{portfolio.label}</p>
        <h2 class="font-serif text-3xl text-charcoal md:text-4xl lg:text-[2.5rem]">
          {portfolio.title}
        </h2>
        <div class="mt-5 h-px w-10 bg-gold/50" aria-hidden="true"></div>
      </div>
      <a
        href="#contact"
        class="group inline-flex items-center gap-4 text-[11px] font-medium uppercase tracking-[0.2em] text-charcoal"
      >
        {portfolio.archiveLink}
        <span class="h-px w-12 bg-charcoal/30 transition-all group-hover:w-20 group-hover:bg-gold"></span>
      </a>
    </div>

    <div class="mb-14 max-w-3xl rounded-sm border border-charcoal/6 bg-white p-6 md:p-8">
      <h3 class="font-serif text-lg text-charcoal md:text-xl">{portfolio.intro.title}</h3>
      <p class="mt-4 text-sm leading-relaxed text-muted md:text-base">
        {portfolio.intro.description}
      </p>
    </div>

    <div class="grid gap-10 sm:grid-cols-2 sm:gap-x-8 sm:gap-y-14">
      {
        portfolio.projects.map((project) => (
          <article class="group">
            <div class="overflow-hidden bg-white shadow-[0_4px_20px_-4px_rgba(26,26,26,0.08)] transition-shadow duration-500 group-hover:shadow-[0_12px_40px_-8px_rgba(26,26,26,0.14)]">
              <img
                src={project.image}
                alt={project.title}
                class="aspect-[4/3] w-full object-cover transition-all duration-700 group-hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
            <h3 class="mt-5 font-serif text-xl text-charcoal transition-colors group-hover:text-gold md:text-2xl">
              {project.title}
            </h3>
            <p class="mt-2 text-[11px] font-medium uppercase tracking-[0.2em] text-muted">
              {project.category} · {project.year}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
