---
import type { SiteContent } from '../i18n';
import { imageSrc } from '../utils/image';

interface Props {
  content: SiteContent;
}

const { portfolio } = Astro.props.content;
---

<section id="portfolio" class="bg-cream py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="mb-16 flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
      <div data-animate>
        <p class="section-label mb-5">{portfolio.label}</p>
        <h2 class="font-serif text-3xl font-normal text-charcoal md:text-4xl lg:text-[2.75rem]">
          {portfolio.title}
        </h2>
      </div>
      <a href="#contact" class="link-arrow shrink-0" data-animate data-delay="2">
        {portfolio.archiveLink}
        <span aria-hidden="true"></span>
      </a>
    </div>

    <div class="grid gap-16 md:grid-cols-2 lg:gap-x-16 lg:gap-y-20">
      {
        portfolio.projects.map((project, index) => {
          const isEvenCol = index % 2 === 0;

          return (
            <article
              class:list={[
                'group',
                !isEvenCol && 'layout-stagger-col-even',
                isEvenCol ? 'md:pr-4 lg:pr-8' : 'md:pl-4 lg:pl-8',
              ]}
              data-animate
              data-delay={String((index % 2) + 1)}
            >
              <div
                class:list={[
                  'overflow-hidden',
                  isEvenCol ? 'layout-offset-right' : 'layout-offset-left',
                  index % 4 < 2 ? 'layout-offset-down' : 'layout-offset-up',
                ]}
                data-animate="image"
              >
                <img
                  src={imageSrc(project.image)}
                  alt={project.title}
                  class="aspect-[3/2] w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
                  loading="lazy"
                />
              </div>
              <div
                class:list={[
                  'mt-6 border-t border-border pt-6 transition-colors duration-300 group-hover:border-charcoal/30',
                  isEvenCol ? 'md:ml-6 lg:ml-10' : 'md:mr-6 lg:mr-10 md:text-right',
                ]}
              >
                <h3 class="font-serif text-xl font-normal text-charcoal md:text-2xl">
                  {project.title}
                </h3>
                <p class="mt-2 text-[10px] font-normal uppercase tracking-[0.25em] text-stone">
                  {project.category}
                </p>
                {project.tagline && (
                  <p class="mt-4 text-sm leading-relaxed text-muted">{project.tagline}</p>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
