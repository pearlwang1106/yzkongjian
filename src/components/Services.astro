---
import type { SiteContent } from '../i18n';
import { imageSrc } from '../utils/image';

interface Props {
  content: SiteContent;
}

const { services, included } = Astro.props.content;

// 左右列图片偏上，中间列图片偏下，形成上下错落
const imageStagger = [
  'layout-offset-up',
  'layout-offset-down',
  'layout-offset-up',
];
---

<section id="services" class="relative overflow-hidden bg-white py-20 md:py-28">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-b from-section-alt/50 via-transparent to-section-alt/25"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-5 md:px-8">
    <div class="section-header text-center" data-animate>
      <p class="section-label mb-5">{services.label}</p>
      <h2 class="section-title">{services.title}</h2>
    </div>

    <div class="grid gap-14 md:grid-cols-3 md:gap-8 lg:gap-10">
      {
        services.items.map((item, index) => {
          const isMiddle = index === 1;

          const imageBlock = (
            <div
              class:list={[
                'overflow-hidden',
                imageStagger[index],
                isMiddle ? 'order-2 md:mt-6' : 'order-1',
              ]}
              data-animate="image"
              data-delay={String(index + 1)}
            >
              <img
                src={imageSrc(item.image)}
                alt={item.imageAlt}
                class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
          );

          const textBlock = (
            <div
              class:list={[
                'border-t border-border pt-6 transition-colors duration-300 group-hover:border-charcoal/25 md:pt-8',
                isMiddle ? 'order-1' : 'order-2 mt-6 md:mt-8',
              ]}
            >
              <p class="text-[10px] font-normal uppercase tracking-[0.3em] text-stone transition-colors duration-300 group-hover:text-charcoal">
                {item.number}
              </p>
              <h3 class="mt-4 font-serif text-xl font-normal text-charcoal md:text-2xl">
                {item.title}
              </h3>
              <ul class="mt-5 space-y-2.5">
                {item.description.map((line) => (
                  <li class="text-sm leading-relaxed text-muted">{line}</li>
                ))}
              </ul>
            </div>
          );

          return (
            <article
              class="group flex flex-col"
              data-animate
              data-delay={String(index + 1)}
            >
              {imageBlock}
              {textBlock}
            </article>
          );
        })
      }
    </div>

    <div class="mt-20 border-t border-border pt-12 md:mt-24" data-animate>
      <p class="section-label mb-8 text-center">{included.label}</p>
      <ul class="flex flex-wrap items-center justify-center gap-x-12 gap-y-3">
        {
          included.items.map((item, index) => (
            <li
              class="text-sm text-muted transition-colors duration-300 hover:text-charcoal"
              data-animate
              data-delay={String(index + 1)}
            >
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
