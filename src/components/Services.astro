---
import { services, included } from '../data/zh';
---

<section id="services" class="bg-white py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="section-header">
      <p class="section-label mb-4">{services.label}</p>
      <h2 class="section-title">{services.title}</h2>
    </div>

    <div class="grid gap-6 md:grid-cols-3 md:gap-8">
      {
        services.items.map((item) => (
          <article class="group border border-charcoal/8 bg-white p-8 transition-all duration-300 hover:border-gold/30 hover:shadow-[0_8px_30px_-8px_rgba(26,26,26,0.08)] md:p-10">
            <p class="font-serif text-5xl leading-none text-gold/80 transition-colors group-hover:text-gold md:text-6xl">
              {item.number}
            </p>
            <h3 class="mt-6 font-serif text-xl text-charcoal md:text-2xl">{item.title}</h3>
            <ul class="mt-5 space-y-3 border-t border-charcoal/6 pt-5">
              {item.description.map((line) => (
                <li class="text-sm leading-relaxed text-muted">{line}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>

    <div class="mt-20 rounded-sm bg-section-alt px-6 py-10 md:mt-24 md:px-10 md:py-12">
      <p class="section-label mb-8 text-center">{included.label}</p>
      <ul class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
        {
          included.items.map((item) => (
            <li class="flex items-center gap-2 text-sm text-muted">
              <span class="h-1 w-1 rounded-full bg-gold" aria-hidden="true"></span>
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
